---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import FlashDeal from '../components/FlashDeal.astro';
import HeroElegant from '../components/HeroElegant.astro';
import FloatingBuy from '../components/FloatingBuy.astro';
import TokenomicsElegant from '../components/TokenomicsElegant.astro';
import RoadmapHorizontal from '../components/RoadmapHorizontal.astro';
import BuySection from '../components/BuySection.astro';
import UtilityBento from '../components/UtilityBento.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="Shrek Token // $SHREK - The Swamp-Owned Meme King">
  <FlashDeal />
	<Navigation />
	<main>
		<HeroElegant />

    <CTASection 
      title="🚀 IT'S ALL OGER NOW" 
      subtitle="The swamp evolution starts today. SECURE YOUR BAG NOW."
      buttonText="BUY $SHREK BEFORE IT'S GONE"
      type="success"
    />

		<BuySection />

    <CTASection 
      title="🔥 GET OUT OF MY SWAMP" 
      subtitle="Every 0.1 SOL gives you a 10X chance to win the Swampy $10,000 Airdrop!"
      buttonText="SEND SOL NOW"
      type="primary"
    />

		<TokenomicsElegant />
		<UtilityBento />

    <CTASection 
      title="🛡️ SWAMP-TESTED & OGRE SECURE" 
      subtitle="Join the 1,000,000,000 supply onion-loving elite squad."
      buttonText="JOIN THE SWAMP"
      type="dark"
    />

		<RoadmapHorizontal />
	</main>
	<Footer />
  <FloatingBuy />
</Layout>

<style>
	main {
		width: 100%;
		overflow-x: hidden;
	}
</style>
