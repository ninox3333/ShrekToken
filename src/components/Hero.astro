---
---
<section class="hero">
  <div class="fire-glow" style="top: 20%; left: 50%; translate: -50% -50%;"></div>
  
  <div class="container hero-content">
    <div class="hero-text-area">
      <div class="badge">
        <span class="live-dot"></span>
        PRESALE LIVE
      </div>
      <h1>SWAMP YOUR WEALTH <br/> <span class="text-gradient">// IT'S ALL OGER</span></h1>
      <p class="description">
        Forged in the depths of the swamp, Shrek Token is a 1,000,000,000 supply, ultra-fast meme asset engineered to empower a fearless community. Every layer of the onion adds scarcity, every holder becomes part of the swamp.
      </p>
      
      <div class="hero-actions">
        <a href="#buy" class="btn btn-primary">EXPLORE ONIONOMICS</a>
        <a href="#buy" class="btn btn-success">BUY $SHREK</a>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value">1B</span>
          <span class="stat-label">Total Supply</span>
        </div>
        <div class="stat">
          <span class="stat-value">60s</span>
          <span class="stat-label">Airdrop Speed</span>
        </div>
        <div class="stat">
          <span class="stat-value">$10K</span>
          <span class="stat-label">Swampy Bounty</span>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="token-container">
        <div class="token-glow"></div>
        <div class="token-mockup">
          <img src="/logo.png" alt="Shrek Token" class="hero-logo" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 4rem 0;
    overflow: hidden;
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255, 77, 0, 0.1);
    border: 1px solid var(--primary);
    color: var(--primary);
    padding: 0.5rem 1.25rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 800;
    margin-bottom: 2rem;
    letter-spacing: 0.15em;
    box-shadow: 0 0 20px rgba(255, 77, 0, 0.2);
    animation: badge-glow 3s infinite alternate;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    background-color: var(--primary);
    border-radius: 50%;
    position: relative;
  }

  .live-dot::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--primary);
    border-radius: 50%;
    animation: pulse-ring 1.5s cubic-bezier(0.455, 0.03, 0.515, 0.955) infinite;
  }

  @keyframes pulse-ring {
    0% { transform: scale(0.33); opacity: 1; }
    80%, 100% { transform: scale(3); opacity: 0; }
  }

  @keyframes badge-glow {
    from { box-shadow: 0 0 10px rgba(255, 77, 0, 0.1); border-color: rgba(255, 77, 0, 0.5); }
    to { box-shadow: 0 0 25px rgba(255, 77, 0, 0.4); border-color: var(--primary); }
  }

  h1 {
    font-size: 4rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .description {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 600px;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .hero-stats {
    display: flex;
    gap: 3rem;
    border-top: 1px solid var(--glass-border);
    padding-top: 2rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--text);
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .token-container {
    position: relative;
    width: 350px;
    height: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .token-mockup {
    width: 250px;
    height: 250px;
    background: transparent;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 50px var(--primary-glow);
    border: 4px solid rgba(255, 77, 0, 0.3);
    position: relative;
    z-index: 2;
    animation: float 6s ease-in-out infinite;
  }

  .hero-logo {
    width: 100%;
    max-width: 350px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 30px var(--primary-glow));
    transition: transform 0.3s ease;
  }
  
  .hero-logo:hover {
    transform: scale(1.05) rotate(2deg);
  }

  .token-glow {
    position: absolute;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, var(--primary-glow) 0%, transparent 70%);
    filter: blur(40px);
    z-index: 1;
    animation: pulse-glow 4s infinite alternate;
  }

  @media (max-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
    }
    
    .hero-content .hero-text-area {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    h1 {
      font-size: 3rem;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-stats {
      justify-content: center;
    }

    .hero-visual {
      margin-top: 3rem;
    }
  }

  @media (max-width: 480px) {
    h1 {
      font-size: 2.2rem;
    }
    
    .hero-stats {
      gap: 1.5rem;
    }
    
    .token-container {
      width: 200px;
      height: 200px;
    }
    
    .token-mockup {
      width: 150px;
      height: 150px;
      font-size: 5rem;
    }
  }
</style>
