---
---
<section class="utility" id="utility">
  <div class="container utility-content">
    <div class="visual-area">
      <div class="fire-ring">
        <img src="/logo.png" alt="Charizard Utility" class="utility-logo" />
      </div>
    </div>
    
    <div class="text-area">
      <h2 class="text-gradient">Utility that Breathes Fire</h2>
      <p class="section-desc">Charizard Token is a wealth-engine built for blazing-fast transactions and gamified rewards.</p>
      
      <div class="utility-list">
        <div class="utility-box">
          <div class="u-icon">⚡</div>
          <div class="u-text">
            <h3>Flash Transfers</h3>
            <p>Optimized for low fees, even when the market heats up.</p>
          </div>
        </div>
        <div class="utility-box">
          <div class="u-icon">🥩</div>
          <div class="u-text">
            <h3>Ember Rewards</h3>
            <p>Earn rewards by staking $CHZ during community burn campaigns.</p>
          </div>
        </div>
        <div class="utility-box">
          <div class="u-icon">🎮</div>
          <div class="u-text">
            <h3>Metaverse Arenas</h3>
            <p>Unlock exclusive drops, merch, and arenas with your holdings.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .utility {
    padding: 5rem 0;
    background: rgba(0,0,0,0.3);
  }

  .utility-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .visual-area {
    display: flex;
    justify-content: center;
  }

  .fire-ring {
    width: 240px;
    height: 240px;
    border: 2px solid var(--primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    box-shadow: 0 0 40px var(--primary-glow);
  }

  .fire-ring::after {
    content: '';
    position: absolute;
    width: 110%;
    height: 110%;
    border: 1px dashed var(--secondary);
    border-radius: 50%;
    animation: rotate 20s linear infinite;
  }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .utility-logo {
    width: 85%;
    height: auto;
    animation: float 4s ease-in-out infinite;
    filter: drop-shadow(0 0 15px var(--primary-glow));
    object-fit: contain;
  }

  .section-desc {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .utility-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .utility-box {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--glass);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    transition: 0.3s;
  }

  .utility-box:hover {
    background: rgba(255, 77, 0, 0.05);
    border-color: var(--primary);
    transform: translateX(10px);
  }

  .u-icon {
    font-size: 2rem;
  }

  .u-text h3 {
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .u-text p {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .utility-content { grid-template-columns: 1fr; gap: 3rem; text-align: center; }
    .utility-box { text-align: left; }
    .fire-ring { width: 200px; height: 200px; }
    .inner-icon { font-size: 4rem; }
  }
</style>
