<div class="buy-floating" id="buy-floater">
  <div class="swamp-glow"></div>
  <a href="#buy" class="float-btn">
    <span class="btn-icon">💰</span>
    <span class="btn-text">BUY $SHREK</span>
  </a>
</div>

<style>
  .buy-floating {
    position: fixed;
    bottom: 40px;
    right: 40px;
    z-index: 1000;
    pointer-events: none;
    transition: all 0.5s ease;
  }

  .swamp-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(164, 198, 57, 0.2) 0%, transparent 70%);
    z-index: -1;
    animation: drift 4s infinite alternate;
    pointer-events: none;
  }

  @keyframes drift {
    from { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
    to { transform: translate(-50%, -50%) scale(1.2); opacity: 0.8; }
  }

  .float-btn {
    pointer-events: auto;
    background: var(--primary);
    color: #000;
    padding: 1.25rem 2rem;
    border-radius: 4px;
    font-weight: 950;
    font-size: 1.1rem;
    text-transform: uppercase;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 1rem;
    box-shadow: 
      10px 10px 0 #000,
      0 20px 40px rgba(164, 198, 57, 0.4);
    transition: 0.2s cubic-bezier(0.19, 1, 0.22, 1);
    letter-spacing: 0.05em;
    border: 2px solid #000;
  }

  .float-btn:hover {
    transform: translate(-4px, -4px);
    box-shadow: 
      14px 14px 0 #000,
      0 25px 50px rgba(164, 198, 57, 0.6);
  }

  .float-btn:active {
    transform: translate(2px, 2px);
    box-shadow: 
      4px 4px 0 #000,
      0 10px 20px rgba(164, 198, 57, 0.4);
  }

  .btn-icon {
    font-size: 1.4rem;
  }

  @media (max-width: 768px) {
    .buy-floating {
      bottom: 20px;
      right: 20px;
    }
    .float-btn {
      padding: 1rem 1.5rem;
      font-size: 0.9rem;
    }
  }
</style>
