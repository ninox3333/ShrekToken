---
// Final push synchronization
---
<div class="flash-deal">
  <div class="container deal-content">
    <div class="deal-badge">🧅 QUICK DEAL</div>
    <p>INSTANT <span class="highlight">Ogre-fast bonuses</span> ON EVERY PURCHASE!</p>
    <div class="countdown" id="deal-countdown">
      LAYERS CLOSING IN: <span id="timer">12:54:21</span>
    </div>
    <a href="#buy" class="deal-btn">SECURE $SHREK</a>
  </div>
</div>

<style>
  .flash-deal {
    background: linear-gradient(90deg, #A4C639, #7AC143, #A4C639);
    background-size: 200% auto;
    animation: gradientMove 3s linear infinite;
    padding: 0.4rem 0;
    margin-top: 0;
    color: #050505;
    font-weight: 800;
    text-align: center;
    position: relative;
    overflow: hidden;
    z-index: 10;
    box-shadow: 0 4px 20px rgba(164, 198, 57, 0.4);
  }

  @keyframes gradientMove {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }

  .deal-content {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
  }

  .deal-badge {
    background: #050505;
    color: #A4C639;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 900;
  }

  .highlight {
    color: #050505;
    font-weight: 900;
    text-decoration: underline;
  }

  .countdown {
    background: rgba(0,0,0,0.1);
    padding: 0.2rem 0.8rem;
    border-radius: 99px;
    font-family: monospace;
    font-size: 0.9rem;
  }

  .deal-btn {
    background: #000;
    color: #fff;
    padding: 0.35rem 1.25rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: 0.2s;
    border: 2px solid transparent;
  }

  .deal-btn:hover {
    background: #fff;
    color: #000;
    transform: scale(1.05) skewX(-5deg);
    border-color: #000;
  }

  @media (max-width: 640px) {
    .deal-content {
      gap: 0.5rem;
      flex-direction: column;
    }
  }
</style>

<script>
  function updateTimer() {
    const timerElement = document.getElementById('timer');
    if (!timerElement) return;

    let totalSeconds = 12 * 3600 + 54 * 60 + 21;
    
    // Simple mock countdown
    setInterval(() => {
      totalSeconds--;
      const hrs = Math.floor(totalSeconds / 3600);
      const mins = Math.floor((totalSeconds % 3600) / 60);
      const secs = totalSeconds % 60;
      
      timerElement.textContent = `${hrs.toString().padStart(2, '0')}:${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
    }, 1000);
  }

  updateTimer();
</script>
