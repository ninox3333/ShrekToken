---
interface Props {
  title?: string;
  subtitle?: string;
  buttonText?: string;
  type?: 'primary' | 'success' | 'dark';
}

const { 
  title = "THE FLAME IS GROWING FAST", 
  subtitle = "Don't miss the chance to be part of the most powerful deflationary token on Solana.", 
  buttonText = "BUY $CHZ NOW",
  type = "success"
} = Astro.props;

const btnClass = type === 'success' ? 'btn-success' : type === 'primary' ? 'btn-primary' : 'btn-outline';
---

<section class={`cta-block ${type}`}>
  <div class="container cta-container">
    <div class="cta-content">
      <h2>{title}</h2>
      <p>{subtitle}</p>
    </div>
    <div class="cta-action">
      <a href="#buy" class={`btn ${btnClass} cta-btn`}>{buttonText}</a>
    </div>
  </div>
</section>

<style>
  .cta-block {
    padding: 3rem 0;
    margin: 1rem 0;
    position: relative;
    overflow: hidden;
  }

  .cta-block::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at center, rgba(255, 77, 0, 0.1) 0%, transparent 70%);
    z-index: -1;
  }

  .primary {
    background: linear-gradient(90deg, rgba(255, 77, 0, 0.05), rgba(255, 31, 0, 0.05));
    border-top: 1px solid rgba(255, 77, 0, 0.1);
    border-bottom: 1px solid rgba(255, 77, 0, 0.1);
  }

  .success {
    background: linear-gradient(90deg, rgba(0, 200, 83, 0.05), transparent);
    border-left: 4px solid #00C853;
  }

  .dark {
    background: #0D0D0D;
    border-top: 1px solid var(--glass-border);
    border-bottom: 1px solid var(--glass-border);
  }

  .cta-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .cta-content h2 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }

  .cta-content p {
    color: var(--text-muted);
    font-size: 1rem;
    max-width: 600px;
  }

  .cta-btn {
    padding: 1.25rem 3rem;
    font-size: 1.1rem;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .cta-container {
      flex-direction: column;
      text-align: center;
    }
    
    .cta-content h2 {
      font-size: 1.5rem;
    }
    
    .cta-btn {
      width: 100%;
    }
  }
</style>
